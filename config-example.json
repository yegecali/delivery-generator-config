      {
        "name": "Database Rollback",
        "url": "https://ci.example.com/db-rollback",
        "parameters": [
          { "name": "rollbackPoint", "type": "string", "required": true },
          { "name": "backup", "type": "boolean", "required": true }
        ]
      },
      {
        "name": "Circuit Breaker Off",
        "url": "https://ci.example.com/circuit-breaker-off",
        "parameters": [
          { "name": "service", "type": "string", "required": true }
        ]
      },
      {
        "name": "Health Check Reset",
        "url": "https://ci.example.com/health-reset",
        "parameters": [
          { "name": "endpoints", "type": "string", "required": false },
          { "name": "force", "type": "boolean", "required": false }
        ]
      }
    ]
  }
}