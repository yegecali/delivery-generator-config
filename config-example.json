{
  "Quality": {
    "name": "Quality Environment",
    "pipelinesBuilding": [
      {
        "name": "Build Frontend",
        "url": "https://ci.example.com/build-frontend",
        "parameters": [
          { "name": "branch", "type": "string", "required": true },
          { "name": "nodeVersion", "type": "string", "required": false },
          { "name": "skipTests", "type": "boolean", "required": false },
          { "name": "buildTimeout", "type": "number", "required": false }
        ]
      },
      {
        "name": "Build Backend",
        "url": "https://ci.example.com/build-backend",
        "parameters": [
          { "name": "branch", "type": "string", "required": true },
          { "name": "javaVersion", "type": "string", "required": false },
          { "name": "runSecurityScan", "type": "boolean", "required": false },
          { "name": "environment", "type": "string", "required": true }
        ]
      },
      {
        "name": "Docker Build",
        "url": "https://ci.example.com/docker-build",
        "parameters": [
          { "name": "imageName", "type": "string", "required": true },
          { "name": "tag", "type": "string", "required": true },
          { "name": "registry", "type": "string", "required": false },
          { "name": "pushToRegistry", "type": "boolean", "required": false }
        ]
      },
      {
        "name": "Run Tests",
        "url": "https://ci.example.com/run-tests",
        "parameters": [
          { "name": "testType", "type": "string", "required": true },
          { "name": "coverage", "type": "number", "required": false },
          { "name": "parallel", "type": "boolean", "required": false }
        ]
      },
      {
        "name": "Deploy to QA",
        "url": "https://ci.example.com/deploy-qa",
        "parameters": [
          { "name": "version", "type": "string", "required": true },
          { "name": "replicas", "type": "number", "required": false },
          { "name": "healthCheck", "type": "boolean", "required": false }
        ]
      }
    ],
    "pipelinesReverse": [
      {
        "name": "Rollback QA",
        "url": "https://ci.example.com/rollback-qa",
        "parameters": [
          { "name": "previousVersion", "type": "string", "required": true },
          { "name": "forceRollback", "type": "boolean", "required": false }
        ]
      },
      {
        "name": "Clear Cache",
        "url": "https://ci.example.com/clear-cache",
        "parameters": [
          { "name": "cacheType", "type": "string", "required": true }
