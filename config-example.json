        "name": "Smoke Tests",
        "url": "https://ci.example.com/smoke-tests",
        "parameters": [
          { "name": "endpoints", "type": "string", "required": false },
          { "name": "timeout", "type": "number", "required": false }
        ]
      }
    ]
  },
  "Production": {
    "name": "Production Environment",
    "pipelinesBuilding": [
      {
        "name": "Prod Build & Push",
        "url": "https://ci.example.com/prod-build-push",
        "parameters": [
          { "name": "tag", "type": "string", "required": true },
          { "name": "releaseNotes", "type": "string", "required": false },
          { "name": "isHotfix", "type": "boolean", "required": false }
        ]
      },
      {
        "name": "Canary Deploy",
        "url": "https://ci.example.com/canary-deploy",
        "parameters": [
          { "name": "version", "type": "string", "required": true },
          { "name": "canaryPercentage", "type": "number", "required": true },
          { "name": "duration", "type": "number", "required": false },
          { "name": "metrics", "type": "string", "required": false }
        ]
      },
      {
        "name": "Full Production Deploy",
        "url": "https://ci.example.com/prod-deploy",
        "parameters": [
          { "name": "version", "type": "string", "required": true },
          { "name": "regions", "type": "string", "required": true },
          { "name": "replicas", "type": "number", "required": false },
          { "name": "maintenanceMode", "type": "boolean", "required": false }
        ]
      },
      {
        "name": "Infrastructure Check",
        "url": "https://ci.example.com/infra-check",
        "parameters": [
          { "name": "checkType", "type": "string", "required": true },
          { "name": "fixIssues", "type": "boolean", "required": false }
        ]
      },
      {
        "name": "Database Migration",
        "url": "https://ci.example.com/db-migration",
        "parameters": [
          { "name": "version", "type": "string", "required": true },
          { "name": "backup", "type": "boolean", "required": true },
          { "name": "rollbackPoint", "type": "string", "required": false }
        ]
      }
    ],
    "pipelinesReverse": [
      {
        "name": "Emergency Rollback",
        "url": "https://ci.example.com/emergency-rollback",
        "parameters": [
          { "name": "previousVersion", "type": "string", "required": true },
